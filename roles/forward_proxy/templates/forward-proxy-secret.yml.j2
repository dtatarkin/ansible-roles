apiVersion: v1
kind: Secret
metadata:
  name: forward-proxy
  namespace: {{ forward_proxy_namespace }}
type: Opaque
stringData:
  3proxy.cfg: |
    nscache 65536
    auth strong
{% for user in forward_proxy_users %}
    users {{ user.name }}:CL:{{ user.password }}
{% endfor %}

{% if forward_proxy_internal_network %}
    # Allow internal_network_access users to reach internal network
{% for user in forward_proxy_users | selectattr('internal_network_access') %}
    allow {{ user.name }} * {{ forward_proxy_internal_network }}
{% endfor %}
    # Deny everyone else from internal network
    deny * * {{ forward_proxy_internal_network }}
{% endif %}
    # Allow all authenticated users for public internet
    allow {{ forward_proxy_users | map(attribute='name') | join(',') }}

    proxy -p{{ forward_proxy_port }}
