apiVersion: apps/v1
kind: Deployment
metadata:
  name: forward-proxy
  namespace: {{ forward_proxy_namespace }}
  labels:
    app.kubernetes.io/name: forward-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: forward-proxy
  template:
    metadata:
      labels:
        app.kubernetes.io/name: forward-proxy
    spec:
      containers:
        - name: 3proxy
          image: {{ forward_proxy_image }}
          ports:
            - name: proxy
              containerPort: {{ forward_proxy_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /etc/3proxy/3proxy.cfg
              subPath: 3proxy.cfg
              readOnly: true
          resources:
            requests:
              cpu: {{ forward_proxy_resources.requests.cpu }}
              memory: {{ forward_proxy_resources.requests.memory }}
{% if forward_proxy_resources.limits is defined %}
            limits:
              cpu: {{ forward_proxy_resources.limits.cpu }}
              memory: {{ forward_proxy_resources.limits.memory }}
{% endif %}
        - name: pac-server
          image: {{ forward_proxy_nginx_image }}
          ports:
            - name: http
              containerPort: {{ forward_proxy_pac_port }}
              protocol: TCP
          volumeMounts:
            - name: pac-file
              mountPath: /usr/share/nginx/html/proxy.pac
              subPath: proxy.pac
              readOnly: true
            - name: pac-file
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: nginx.conf
              readOnly: true
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 3
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 15
          resources:
            requests:
              cpu: {{ forward_proxy_pac_resources.requests.cpu }}
              memory: {{ forward_proxy_pac_resources.requests.memory }}
{% if forward_proxy_pac_resources.limits is defined %}
            limits:
              cpu: {{ forward_proxy_pac_resources.limits.cpu }}
              memory: {{ forward_proxy_pac_resources.limits.memory }}
{% endif %}
      volumes:
        - name: config
          secret:
            secretName: forward-proxy
        - name: pac-file
          configMap:
            name: forward-proxy
