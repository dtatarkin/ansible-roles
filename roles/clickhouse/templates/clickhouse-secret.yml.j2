apiVersion: v1
kind: Secret
metadata:
  name: clickhouse-credentials
  namespace: {{ clickhouse_namespace }}
stringData:
  default-password-sha256: {{ clickhouse_password_sha256 }}
{% for user in clickhouse_users %}
  {{ user.name | replace('_', '-') }}-password-sha256: {{ clickhouse_password_hashes[user.name] }}
{% endfor %}
