apiVersion: v1
kind: Service
metadata:
  name: clickhouse-nodeport
  namespace: {{ clickhouse_namespace }}
spec:
  type: NodePort
  ports:
    - name: native
      port: 9000
      targetPort: 9000
      nodePort: {{ clickhouse_node_port_tcp }}
    - name: http
      port: 8123
      targetPort: 8123
      nodePort: {{ clickhouse_node_port_http }}
  selector:
    app.kubernetes.io/name: clickhouse
    app.kubernetes.io/component: server
