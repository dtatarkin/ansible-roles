apiVersion: apps/v1
kind: Deployment
metadata:
  name: temporal-ui
  namespace: {{ temporal_namespace }}
  labels:
    app.kubernetes.io/name: temporal
    app.kubernetes.io/component: ui
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: temporal
      app.kubernetes.io/component: ui
  template:
    metadata:
      labels:
        app.kubernetes.io/name: temporal
        app.kubernetes.io/component: ui
    spec:
      enableServiceLinks: false
      containers:
        - name: temporal-ui
          image: {{ temporal_ui_image }}
          ports:
            - name: http
              containerPort: {{ temporal_ui_port }}
              protocol: TCP
          env:
            - name: TEMPORAL_ADDRESS
              value: "temporal-server.{{ temporal_namespace }}.svc.cluster.local:{{ temporal_grpc_port }}"
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 15
