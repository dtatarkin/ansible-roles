apiVersion: v1
kind: Secret
metadata:
  name: flux-registry-config
  namespace: {{ flux_namespace }}
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: {{ ('{"auths":{"registry.' + infra_domain + '":{"auth":"' + ((docker_registry_username + ":" + flux_docker_registry_password) | b64encode) + '"}}}') | b64encode }}
