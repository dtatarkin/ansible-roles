apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: apps
  namespace: {{ flux_namespace }}
spec:
  interval: 1h
  sourceRef:
    kind: GitRepository
    name: infra
  path: {{ flux_apps_path }}
  prune: true
  decryption:
    provider: sops
    secretRef:
      name: sops-age
