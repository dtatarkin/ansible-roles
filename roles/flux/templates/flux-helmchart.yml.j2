apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: flux
  namespace: kube-system
spec:
  repo: {{ flux_chart_repo }}
  chart: {{ flux_chart_name }}
  version: {{ flux_chart_version }}
  targetNamespace: {{ flux_namespace }}
  valuesContent: |-
    {{ lookup('template', 'flux-values.yml.j2') | indent(4) }}
