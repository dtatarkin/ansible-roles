apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: forward-auth
  namespace: {{ oauth2_proxy_namespace }}
spec:
  forwardAuth:
    address: http://oauth2-proxy.{{ oauth2_proxy_namespace }}.svc.cluster.local:{{ oauth2_proxy_port }}/oauth2/auth
    trustForwardHeader: true
    authResponseHeaders:
      - X-Auth-Request-User
      - X-Auth-Request-Email
