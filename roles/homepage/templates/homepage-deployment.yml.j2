apiVersion: apps/v1
kind: Deployment
metadata:
  name: homepage
  namespace: {{ homepage_namespace }}
  labels:
    app.kubernetes.io/name: homepage
spec:
  revisionHistoryLimit: 3
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: homepage
  template:
    metadata:
      labels:
        app.kubernetes.io/name: homepage
      annotations:
        checksum/config: "{{ homepage_configmap_checksum }}"
    spec:
      serviceAccountName: homepage
      automountServiceAccountToken: true
      initContainers:
        - name: copy-config
          image: busybox:1.37
          command: ["sh", "-c", "cp /config-source/* /app/config/ && mkdir -p /app/config/logs"]
          volumeMounts:
            - name: config-source
              mountPath: /config-source
            - name: config
              mountPath: /app/config
      containers:
        - name: homepage
          image: {{ homepage_image }}
          ports:
            - name: http
              containerPort: {{ homepage_port }}
              protocol: TCP
          env:
            - name: MY_POD_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            - name: HOMEPAGE_ALLOWED_HOSTS
              value: "$(MY_POD_IP):{{ homepage_port }},{{ homepage_allowed_hosts }}"
          volumeMounts:
            - name: config
              mountPath: /app/config
          readinessProbe:
            httpGet:
              path: /api/healthcheck
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /api/healthcheck
              port: http
            initialDelaySeconds: 5
            periodSeconds: 15
      volumes:
        - name: config-source
          configMap:
            name: homepage
        - name: config
          emptyDir: {}
